generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Multi-Tenant: Clinic & Subscription ─────────────────────────────────

model Clinic {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique // subdomain or URL-friendly identifier
  email           String
  phone           String?
  address         String?
  city            String?
  state           String?
  country         String   @default("Singapore")
  zipCode         String?
  website         String?
  logoUrl         String?
  currency        String   @default("SGD")
  timezone        String   @default("Asia/Singapore")
  isActive        Boolean  @default(true)

  // Onboarding & verification
  onboardingComplete Boolean @default(false)
  emailVerified      Boolean @default(false)
  verifyCode         String?
  verifyCodeExpires  DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscription    ClinicSubscription?
}

model ClinicSubscription {
  id              String    @id @default(cuid())
  clinicId        String    @unique
  plan            String    @default("trial") // trial | starter | professional | enterprise
  status          String    @default("active") // active | expired | cancelled | suspended
  trialEndsAt     DateTime? // 7-day trial end date
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  maxUsers        Int       @default(5) // trial = 5, starter = 10, etc.
  maxPatients     Int       @default(100) // trial = 100
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  paymentMethod   String?
  paymentReference String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  clinic          Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}

// ─── Patients ────────────────────────────────────────────────────────────

model Patient {
  id              String   @id @default(cuid())
  clinicId        String?
  patientIdNumber String   @default("")
  firstName       String
  lastName        String
  nricId          String?
  email           String?
  phone           String
  secondaryMobile String?
  landline        String?
  whatsapp        String?
  dateOfBirth     DateTime?
  age             Int?
  gender          String
  address         String?
  locality        String?
  city            String?
  state           String?
  zipCode         String?
  bloodGroup      String?
  ethnicity       String?
  nationality     String?
  occupation      String?
  referredBy      String?
  familyRelation  String?
  familyMemberName String?
  emergencyName   String?
  emergencyPhone  String?

  // Medical History (stored as JSON string)
  medicalHistory  String   @default("[]")
  otherHistory    String?
  allergies       String?
  medicalNotes    String?

  // Groups (stored as JSON string)
  groups          String   @default("[]")

  photoUrl        String?
  status          String   @default("active")
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  communications Communication[]
  appointments   Appointment[]
  clinicalNotes  ClinicalNote[]
  documents      Document[]
  familyMembers  FamilyMember[]
  vitals         Vital[]
  reminders      Reminder[]
  treatmentPlans TreatmentPlan[]
  prescriptions  Prescription[]
  patientPackages PatientPackage[]

  @@unique([clinicId, patientIdNumber])
  @@index([clinicId])
}

model FamilyMember {
  id              String   @id @default(cuid())
  clinicId        String?
  patientId       String
  relation        String   // spouse | parent | child | sibling | grandparent | grandchild | uncle_aunt | nephew_niece | cousin | other
  linkedPatientId String?  // optional FK to another Patient record
  memberName      String   // display name (auto-filled from linked patient or manually entered)
  memberPhone     String?
  memberGender    String?  // "male" | "female" — used for gender-aware labels
  createdAt       DateTime @default(now())

  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

// Doctor model removed — merged into User model

model Appointment {
  id              String   @id @default(cuid())
  clinicId        String?
  patientId       String?
  doctorId        String?
  date            DateTime
  time            String
  endTime         String?
  duration        Int      @default(15) // minutes
  doctor          String   // doctor name (kept for backward compat)
  department      String?
  type            String   @default("consultation") // consultation | follow-up | procedure | emergency
  reason          String?
  notes           String?
  status          String   @default("scheduled") // scheduled | confirmed | in-progress | completed | cancelled | no-show

  // Walk-in / unregistered patient fields
  walkinName      String?
  walkinPhone     String?
  isWalkin        Boolean  @default(false)

  // Treatment & Package linkage
  treatmentId     String?
  packageId       String?
  treatmentName   String?  // denormalized for display
  packageName     String?  // e.g. "10-Session Package"
  sessionPrice    Float?   // price for this session (single or per-session from package)
  packageTotal    Float?   // total package price (null for single sessions)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient         Patient?  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorRef       User?    @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  treatment       Treatment? @relation(fields: [treatmentId], references: [id], onDelete: SetNull)
  treatmentPkg    TreatmentPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@index([clinicId])
  @@index([date])
  @@index([patientId])
  @@index([doctorId])
}

model Communication {
  id        String   @id @default(cuid())
  clinicId  String?
  patientId String
  type      String   // "email" | "whatsapp"
  subject   String?
  message   String
  status    String   @default("sent")
  sentAt    DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([patientId])
}

model ClinicalNote {
  id              String   @id @default(cuid())
  clinicId        String?
  patientId       String
  type            String   // "present_illness" | "past_history" | "personal_history" | "examination" | "diagnosis" | "treatment" | "general"
  title           String
  content         String
  doctor          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([clinicId])
}

model Document {
  id          String   @id @default(cuid())
  clinicId    String?
  patientId   String
  fileName    String
  fileType    String   // MIME type
  fileSize    Int      // bytes
  filePath    String   // stored path
  category    String   @default("report") // "report" | "lab" | "imaging" | "prescription" | "other"
  description String?
  uploadedAt  DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([clinicId])
}

// ─── Vitals Tracking ─────────────────────────────────────────────────────

model Vital {
  id              String   @id @default(cuid())
  clinicId        String?
  patientId       String
  appointmentId   String?
  date            DateTime @default(now())

  // Core vitals
  bloodPressureSys  Int?     // systolic mmHg
  bloodPressureDia  Int?     // diastolic mmHg
  pulse             Int?     // bpm
  temperature       Float?   // °C
  weight            Float?   // kg
  height            Float?   // cm
  bmi               Float?   // auto-calculated
  oxygenSaturation  Int?     // SpO2 %
  respiratoryRate   Int?     // breaths/min

  notes           String?
  recordedBy      String?
  createdAt       DateTime @default(now())

  patient         Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

// ─── Treatments & Packages ────────────────────────────────────────────────

model Treatment {
  id              String   @id @default(cuid())
  clinicId        String?
  name            String
  description     String?
  category        String   @default("therapy") // therapy | consultation | panchakarma | massage | detox | specialty
  duration        Int      @default(50) // minutes
  basePrice       Float    @default(0) // single session price in SGD
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  packages        TreatmentPackage[]
  appointments    Appointment[]
  patientPackages PatientPackage[]
}

model TreatmentPackage {
  id              String   @id @default(cuid())
  clinicId        String?
  treatmentId     String
  name            String   // e.g. "10-Session Package"
  sessionCount    Int      // number of sessions
  discountPercent Float    @default(0) // e.g. 20 = 20% off
  totalPrice      Float    @default(0) // calculated: basePrice * sessionCount * (1 - discount/100)
  pricePerSession Float    @default(0) // calculated: totalPrice / sessionCount
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  treatment       Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  patientPackages PatientPackage[]
}

// ─── Inventory Management ─────────────────────────────────────────────────

model InventoryItem {
  id              String   @id @default(cuid())
  clinicId        String?
  sku             String
  name            String
  category        String   @default("medicine") // medicine | herb | oil | consumable | equipment
  subcategory     String?  // e.g. "Kashayam", "Arishtam", "Choornam", "Thailam", "Ghritam", "Leham"
  unit            String   @default("nos") // nos | ml | gm | kg | litre | bottle | packet | box
  packing         String?  // e.g. "450ML", "10GM", "100Nos" — actual size/packing from manufacturer
  manufacturerCode String? // Kottakkal/manufacturer product code e.g. "FGA001"
  unitPrice       Float    @default(0)     // selling price (MRP)
  costPrice       Float    @default(0)     // purchase/cost price (Basic Price)
  currentStock    Int      @default(0)
  reorderLevel    Int      @default(10)    // alert when stock falls below
  expiryDate      DateTime?
  batchNumber     String?
  manufacturer    String?
  supplier        String?
  location        String?  // storage location in clinic
  hsnCode         String?  // HSN code for GST
  gstPercent      Float    @default(0)
  description     String?
  status          String   @default("active") // active | discontinued | out_of_stock
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions    StockTransaction[]
  variants        InventoryVariant[]
  branchStock     BranchStock[]
  transferItems   StockTransferItem[]

  @@unique([clinicId, sku])
  @@index([clinicId])
}

model InventoryVariant {
  id              String   @id @default(cuid())
  clinicId        String?
  itemId          String
  manufacturerCode String? // Kottakkal code for this specific variant
  packing         String   // e.g. "200ML", "50GM"
  unitPrice       Float    @default(0)     // MRP for this variant
  costPrice       Float    @default(0)     // Basic Price for this variant
  currentStock    Int      @default(0)
  gstPercent      Float    @default(0)
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  item            InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model StockTransaction {
  id              String   @id @default(cuid())
  clinicId        String?
  itemId          String
  variantId       String?  // linked to specific variant if applicable
  type            String   // purchase | sale | adjustment | return | expired | damaged
  quantity        Int      // positive = stock in, negative = stock out
  unitPrice       Float    @default(0)
  totalAmount     Float    @default(0)
  previousStock   Int      @default(0)
  newStock        Int      @default(0)
  reference       String?  // invoice number, PO number, etc.
  notes           String?
  performedBy     String?  // who did this transaction
  date            DateTime @default(now())
  createdAt       DateTime @default(now())

  item            InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model Supplier {
  id              String   @id @default(cuid())
  clinicId        String?
  name            String
  contactPerson   String?
  phone           String?
  email           String?
  address         String?
  gstNumber       String?
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Clinic Settings (per-clinic) ───────────────────────────────────────

model ClinicSettings {
  id                String   @id @default(cuid())
  clinicId          String?  @unique
  clinicName        String   @default("Ayur Centre Pte. Ltd.")
  address           String   @default("84 Bedok North Street 4 #01-17")
  city              String   @default("Singapore")
  state             String   @default("Singapore")
  zipCode           String   @default("460084")
  phone             String   @default("6445 0072")
  email             String   @default("ayurcentresg@gmail.com")
  website           String   @default("www.ayurcentre.sg")
  logoUrl           String?
  gstRegistrationNo String   @default("")
  termsAndConditions String  @default("Payment is due upon receipt. Medical services are subject to GST at prevailing rates.")
  currency          String   @default("SGD")
  dateFormat        String   @default("dd/MM/yyyy")
  timeFormat        String   @default("12h")
  appointmentDuration Int    @default(30)
  workingHoursStart String   @default("09:00")
  workingHoursEnd   String   @default("18:00")
  workingDays       String   @default("[1,2,3,4,5,6]")
  updatedAt         DateTime @updatedAt
}

// ─── Billing System ───────────────────────────────────────────────────────

model Invoice {
  id              String   @id @default(cuid())
  clinicId        String?
  invoiceNumber   String
  patientId       String?
  appointmentId   String?
  branchId        String?
  date            DateTime @default(now())
  dueDate         DateTime?

  // Patient info (denormalized for walk-ins)
  patientName     String
  patientPhone    String?

  // Amounts
  subtotal        Float    @default(0)
  discountPercent Float    @default(0)
  discountAmount  Float    @default(0)
  taxableAmount   Float    @default(0)
  gstAmount       Float    @default(0)
  totalAmount     Float    @default(0)
  paidAmount      Float    @default(0)
  balanceAmount   Float    @default(0)

  // Status & payment
  status          String   @default("draft") // draft | pending | paid | partially_paid | cancelled | refunded
  paymentMethod   String?  // cash | card | upi | insurance | mixed
  paymentNotes    String?

  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           InvoiceItem[]
  payments        Payment[]
  insuranceClaims InsuranceClaim[]
  creditNotes     CreditNote[]

  @@unique([clinicId, invoiceNumber])
  @@index([clinicId])
  @@index([patientId])
  @@index([date])
}

model InvoiceItem {
  id              String   @id @default(cuid())
  clinicId        String?
  invoiceId       String
  type            String   // consultation | therapy | medicine | procedure | lab | other
  description     String
  hsnSacCode      String?  // HSN/SAC code for GST classification
  inventoryItemId String?  // linked to inventory for medicines
  variantId       String?  // linked to specific variant if applicable
  quantity        Int      @default(1)
  unitPrice       Float    @default(0)
  discount        Float    @default(0)
  gstPercent      Float    @default(0)
  gstAmount       Float    @default(0)
  amount          Float    @default(0) // final amount after discount + gst

  invoice         Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([clinicId])
}

model Payment {
  id              String   @id @default(cuid())
  clinicId        String?
  invoiceId       String
  receiptNumber   String?
  amount          Float
  method          String   // cash | card | upi | insurance | bank_transfer
  reference       String?  // transaction ID, cheque number, etc.
  notes           String?
  date            DateTime @default(now())
  createdAt       DateTime @default(now())

  invoice         Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([clinicId, receiptNumber])
  @@index([invoiceId])
  @@index([clinicId])
}

// ─── Insurance ───────────────────────────────────────────────────────────

model InsuranceProvider {
  id              String   @id @default(cuid())
  clinicId        String?
  name            String
  code            String
  contactPerson   String?
  phone           String?
  email           String?
  address         String?
  panelType       String   @default("private") // corporate | government | private
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  claims          InsuranceClaim[]

  @@unique([clinicId, code])
}

model InsuranceClaim {
  id              String   @id @default(cuid())
  clinicId        String?
  claimNumber     String
  invoiceId       String
  providerId      String
  patientId       String?
  patientName     String

  // Amounts
  claimAmount     Float    @default(0)
  approvedAmount  Float?
  settledAmount   Float?

  // Pre-authorization
  preAuthNumber   String?
  preAuthStatus   String?  // pending | approved | denied
  preAuthAmount   Float?

  // Status workflow: submitted → under_review → approved/partially_approved/rejected → settled
  status          String   @default("submitted")
  submittedDate   DateTime @default(now())
  reviewDate      DateTime?
  approvedDate    DateTime?
  settledDate     DateTime?
  rejectionReason String?
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoice         Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  provider        InsuranceProvider  @relation(fields: [providerId], references: [id])

  @@unique([clinicId, claimNumber])
}

// ─── Credit Notes ────────────────────────────────────────────────────────

model CreditNote {
  id                String   @id @default(cuid())
  clinicId          String?
  creditNoteNumber  String
  invoiceId         String
  reason            String
  items             String   @default("[]") // JSON: [{description, amount, gstAmount}]
  subtotal          Float    @default(0)
  gstAmount         Float    @default(0)
  totalAmount       Float    @default(0)
  status            String   @default("draft") // draft | issued | applied | voided
  refundMethod      String?  // cash | card | upi | bank_transfer
  refundReference   String?
  refundDate        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  invoice           Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([clinicId, creditNoteNumber])
}

// ─── Purchase Orders ─────────────────────────────────────────────────────

model PurchaseOrder {
  id              String   @id @default(cuid())
  clinicId        String?
  poNumber        String
  supplierId      String
  supplierName    String
  status          String   @default("draft") // draft, submitted, partial, received, cancelled
  orderDate       DateTime @default(now())
  expectedDate    DateTime?
  receivedDate    DateTime?
  subtotal        Float    @default(0)
  gstAmount       Float    @default(0)
  totalAmount     Float    @default(0)
  paidAmount      Float    @default(0)
  notes           String?
  createdBy       String?
  branchId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  items           PurchaseOrderItem[]

  @@unique([clinicId, poNumber])
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  clinicId        String?
  purchaseOrderId String
  inventoryItemId String?
  variantId       String?  // linked to specific variant if applicable
  itemName        String
  sku             String?
  quantity        Int
  receivedQty     Int      @default(0)
  unitPrice       Float
  gstPercent      Float    @default(0)
  totalAmount     Float
  notes           String?
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

// ─── Message Templates & Reminders ──────────────────────────────────────

model MessageTemplate {
  id          String   @id @default(cuid())
  clinicId    String?
  name        String
  channel     String   // whatsapp, email, sms
  subject     String?  // for email
  body        String   // supports variables like {{patientName}}, {{appointmentDate}}, {{doctorName}}, {{clinicName}}, {{amount}}
  category    String   // appointment_reminder, follow_up, payment_reminder, medication, welcome, birthday, custom
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Reminder {
  id              String   @id @default(cuid())
  clinicId        String?
  patientId       String
  appointmentId   String?
  type            String   // appointment, follow_up, payment, medication, custom
  channel         String   // whatsapp, email, sms
  scheduledAt     DateTime
  sentAt          DateTime?
  status          String   @default("pending") // pending, sent, failed, cancelled
  message         String
  templateId      String?
  notes           String?
  createdAt       DateTime @default(now())
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

// ─── Prescriptions ──────────────────────────────────────────────────────

model Prescription {
  id              String   @id @default(cuid())
  clinicId        String?
  prescriptionNo  String
  patientId       String
  doctorId        String?
  doctorName      String
  diagnosis       String?
  notes           String?
  status          String   @default("active") // active, completed, cancelled
  date            DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  items           PrescriptionItem[]

  @@unique([clinicId, prescriptionNo])
}

model PrescriptionItem {
  id              String   @id @default(cuid())
  clinicId        String?
  prescriptionId  String
  medicineName    String
  inventoryItemId String?  // link to InventoryItem if from stock
  dosage          String   // e.g., "500mg", "10ml", "2 tablets"
  frequency       String   // e.g., "twice_daily", "thrice_daily", "once_daily"
  timing          String?  // e.g., "after_food", "before_food", "with_food"
  duration        String   // e.g., "7 days", "2 weeks", "1 month"
  quantity        Int?     // total quantity to dispense
  instructions    String?  // special instructions
  sequence        Int      @default(0)
  prescription    Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
}

// ─── Treatment Plans ────────────────────────────────────────────────────

model TreatmentPlan {
  id              String   @id @default(cuid())
  clinicId        String?
  planNumber      String
  patientId       String
  doctorId        String?
  doctorName      String
  name            String   // e.g., "Lower Back Pain Management", "Detox Program"
  description     String?
  diagnosis       String?
  goals           String?  // treatment goals
  startDate       DateTime @default(now())
  endDate         DateTime?
  status          String   @default("active") // active, completed, paused, cancelled
  totalSessions   Int      @default(0)
  completedSessions Int    @default(0)
  totalCost       Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  items           TreatmentPlanItem[]
  milestones      TreatmentMilestone[]

  @@unique([clinicId, planNumber])
}

model TreatmentPlanItem {
  id              String   @id @default(cuid())
  clinicId        String?
  planId          String
  treatmentId     String?
  treatmentName   String
  category        String?
  frequency       String   // e.g., "2x per week", "daily", "once per week", "alternate days"
  totalSessions   Int
  completedSessions Int    @default(0)
  sessionPrice    Float    @default(0)
  totalCost       Float    @default(0)
  sequence        Int      @default(0) // ordering within plan
  status          String   @default("pending") // pending, in_progress, completed, skipped
  notes           String?
  startDate       DateTime?
  endDate         DateTime?
  plan            TreatmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model TreatmentMilestone {
  id              String   @id @default(cuid())
  clinicId        String?
  planId          String
  title           String
  description     String?
  targetDate      DateTime?
  achievedDate    DateTime?
  status          String   @default("pending") // pending, achieved, missed
  notes           String?
  createdAt       DateTime @default(now())
  plan            TreatmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

// ─── User Management ─────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  clinicId        String?
  name            String
  email           String
  phone           String?
  role            String    @default("staff") // admin | doctor | therapist | pharmacist | receptionist | staff
  password        String    @default("") // hashed placeholder
  isActive        Boolean   @default(true)
  avatar          String?
  totpSecret      String?   // TOTP secret for 2FA (Google Authenticator)
  totpEnabled     Boolean   @default(false) // whether 2FA is active
  lastLogin       DateTime?

  // Staff identification
  staffIdNumber   String?   // D10001, T10001, P10001, R10001, A10001, S10001
  nricFin         String?   // NRIC or FIN number (for KET)
  jobTitle        String?   // e.g. "Administrative Assistant" (for KET, separate from role)
  mainDuties      String?   // job duties description (for KET)
  employmentType  String    @default("full_time") // "full_time" | "part_time"

  // Demographics
  gender          String?   // "male" | "female"
  dateOfBirth     DateTime? // for CPF age-based rates
  ethnicity       String?   // "chinese" | "malay" | "indian" | "eurasian" | "other" — for SHG fund calculation
  residencyStatus String?   // "singaporean" | "pr" | "foreigner" — for CPF/levy logic
  prStartDate     DateTime? // PR effective date — to determine 1st/2nd/3rd year graduated rates
  specialization  String?
  department      String?
  consultationFee Float?
  schedule        String    @default("{}") // weekly schedule JSON
  slotDuration    Int       @default(30)   // minutes per slot
  status          String    @default("active") // active | inactive

  // Employment dates
  dateOfJoining   DateTime? // first day of work
  lastWorkingDate DateTime? // last day if resigned/terminated
  resignationDate DateTime? // date resignation was submitted
  resignationReason String? // reason for leaving

  // Email invite
  inviteToken     String?   @unique // keep globally unique for invite links
  inviteExpiresAt DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  appointments    Appointment[]

  @@unique([clinicId, email])
  @@unique([clinicId, staffIdNumber])
  @@index([clinicId])
}

// ─── Multi-Branch ────────────────────────────────────────────────────────

model Branch {
  id             String   @id @default(cuid())
  clinicId       String?
  name           String
  code           String
  address        String?
  city           String?
  state          String?
  zipCode        String?
  phone          String?
  email          String?
  isActive       Boolean  @default(true)
  isMainBranch   Boolean  @default(false)
  operatingHours String   @default("{}") // JSON
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branchStock    BranchStock[]
  transfersFrom  StockTransfer[] @relation("TransfersFrom")
  transfersTo    StockTransfer[] @relation("TransfersTo")

  @@unique([clinicId, code])
}

// ─── Branch-Level Stock ─────────────────────────────────────────────────

model BranchStock {
  id        String  @id @default(cuid())
  clinicId  String?
  branchId  String
  itemId    String
  variantId String?
  quantity  Int     @default(0)

  branch    Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([branchId, itemId, variantId])
}

// ─── Stock Transfers ────────────────────────────────────────────────────

model StockTransfer {
  id              String    @id @default(cuid())
  clinicId        String?
  transferNumber  String
  fromBranchId    String
  toBranchId      String
  status          String    @default("draft") // draft | in_transit | received | cancelled
  initiatedBy     String?
  receivedBy      String?
  notes           String?
  transferDate    DateTime  @default(now())
  receivedDate    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  fromBranch      Branch              @relation("TransfersFrom", fields: [fromBranchId], references: [id])
  toBranch        Branch              @relation("TransfersTo", fields: [toBranchId], references: [id])
  items           StockTransferItem[]

  @@unique([clinicId, transferNumber])
}

model StockTransferItem {
  id               String  @id @default(cuid())
  clinicId         String?
  transferId       String
  itemId           String
  variantId        String?
  quantitySent     Int
  quantityReceived Int     @default(0)
  notes            String?

  transfer         StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  item             InventoryItem @relation(fields: [itemId], references: [id])
}

// ─── Transfer Templates ─────────────────────────────────────────────────

model TransferTemplate {
  id            String   @id @default(cuid())
  clinicId      String?
  name          String
  description   String?
  fromBranchId  String
  toBranchId    String
  isActive      Boolean  @default(true)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  items         TransferTemplateItem[]
}

model TransferTemplateItem {
  id          String @id @default(cuid())
  clinicId    String?
  templateId  String
  itemId      String
  variantId   String?
  quantity    Int    @default(1)

  template    TransferTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

// ─── Patient Packages ────────────────────────────────────────────────────

model PatientPackage {
  id                String   @id @default(cuid())
  clinicId          String?
  packageNumber     String // PKG-YYYYMM-XXXX
  patientId         String
  treatmentId       String?
  treatmentPackageId String?

  // Denormalized for display
  treatmentName     String
  packageName       String   // e.g. "10-Session Abhyangam Package"

  // Session tracking
  totalSessions     Int
  usedSessions      Int      @default(0)
  remainingSessions Int      // calculated: totalSessions - usedSessions

  // Pricing
  totalPrice        Float    @default(0)
  paidAmount        Float    @default(0)
  balanceAmount     Float    @default(0)
  pricePerSession   Float    @default(0) // totalPrice / totalSessions

  // Dates
  purchaseDate      DateTime @default(now())
  expiryDate        DateTime // default 12 months from purchase, admin configurable
  firstSessionDate  DateTime? // tracks when first session was used (for refund policy)

  // Status
  status            String   @default("active") // active | completed | expired | cancelled | refunded | frozen

  // Sharing
  maxSharedUsers    Int      @default(0) // 0 = no sharing allowed

  // Consultation fee policy
  consultationFeePolicy String @default("doctor_decides") // included | per_visit | doctor_decides

  // Branch & staff
  purchaseBranchId  String?
  soldById          String?  // userId who sold

  // Billing link
  invoiceId         String?  // linked invoice for this package purchase

  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  patient           Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  treatment         Treatment? @relation(fields: [treatmentId], references: [id], onDelete: SetNull)
  treatmentPackage  TreatmentPackage? @relation(fields: [treatmentPackageId], references: [id], onDelete: SetNull)
  sessions          PackageSession[]
  shares            PackageShare[]
  refunds           PackageRefund[]

  @@unique([clinicId, packageNumber])
}

model PackageSession {
  id                String   @id @default(cuid())
  clinicId          String?
  patientPackageId  String
  appointmentId     String?  // linked to actual appointment
  sessionNumber     Int      // 1, 2, 3...

  // Who used this session (for shared packages)
  usedByPatientId   String?
  usedByName        String?  // denormalized

  // Details
  date              DateTime
  doctorName        String?
  branchId          String?

  status            String   @default("completed") // completed | cancelled | no_show
  notes             String?
  createdAt         DateTime @default(now())

  patientPackage    PatientPackage @relation(fields: [patientPackageId], references: [id], onDelete: Cascade)
}

model PackageShare {
  id                String   @id @default(cuid())
  clinicId          String?
  patientPackageId  String
  sharedWithPatientId String
  sharedByPatientId String   // original package owner

  // Denormalized
  sharedWithName    String
  relation          String   @default("other") // family | friend | transfer

  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  patientPackage    PatientPackage @relation(fields: [patientPackageId], references: [id], onDelete: Cascade)
}

model PackageRefund {
  id                String   @id @default(cuid())
  clinicId          String?
  patientPackageId  String
  refundNumber      String // REF-YYYYMM-XXXX

  // CaseTrust policy tracking
  refundType        String   // cooling_off | after_cooling_off_within_5days | beyond_5days
  purchaseDate      DateTime
  firstTreatmentDate DateTime?
  requestDate       DateTime @default(now())

  // Calculation
  totalPackagePrice Float
  completedSessionsValue Float @default(0)
  adminFee          Float    @default(0) // S$100 after cooling-off period
  refundAmount      Float    @default(0)

  // Status
  status            String   @default("pending") // pending | approved | processed | rejected
  processedBy       String?
  processedAt       DateTime?
  creditNoteId      String?  // link to CreditNote

  reason            String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  patientPackage    PatientPackage @relation(fields: [patientPackageId], references: [id], onDelete: Cascade)

  @@unique([clinicId, refundNumber])
}

// ─── Notifications ──────────────────────────────────────────────────────

model Notification {
  id          String   @id @default(cuid())
  clinicId    String?
  type        String   // transfer_incoming | transfer_received | transfer_cancelled | low_stock | po_received | general
  title       String
  message     String
  link        String?  // URL to navigate to when clicked
  branchId    String?  // target branch (null = all branches)
  userId      String?  // target user (null = all users at branch)
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─── Staff Leave / Availability ─────────────────────────────────────────

model StaffLeave {
  id          String   @id @default(cuid())
  clinicId    String?
  userId      String
  type        String   // "leave" | "block" | "holiday"
  title       String   // "Annual Leave", "Sick Leave", "Lunch Block", "Clinic Holiday"
  startDate   DateTime
  endDate     DateTime
  startTime   String?  // null = full day, "14:00" = time-specific block
  endTime     String?  // null = full day, "17:00" = time-specific block
  allDay      Boolean  @default(true)
  status      String   @default("approved") // "pending" | "approved" | "rejected"
  notes       String?
  recurring   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clinicId])
  @@index([userId])
  @@index([startDate, endDate])
}

// ─── Staff Documents ─────────────────────────────────────────────────────

model StaffDocument {
  id          String    @id @default(cuid())
  clinicId    String?
  userId      String
  name        String    // "Medical License", "BAMS Certificate"
  category    String    // "license" | "certificate" | "identification" | "contract" | "other"
  fileName    String    // original file name
  filePath    String    // path on server
  fileSize    Int       // bytes
  mimeType    String    // "application/pdf", "image/jpeg", etc.
  expiryDate  DateTime? // for licenses that expire
  isVerified  Boolean   @default(false)
  notes       String?
  uploadedAt  DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clinicId])
  @@index([userId])
}

// ─── Commission / Incentive Tracking ─────────────────────────────────────

model CommissionRule {
  id              String   @id @default(cuid())
  clinicId        String?
  userId          String?  // null = default rule for all staff
  role            String?  // apply to specific role (doctor, therapist) - used if userId is null
  type            String   @default("percentage") // "percentage" | "fixed"
  value           Float    // e.g., 15 for 15% or 50 for S$50 fixed per appointment
  minRevenue      Float?   // optional: only apply if invoice total >= this amount
  maxCommission   Float?   // optional: cap commission at this amount per month
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clinicId])
}

model CommissionPayout {
  id              String   @id @default(cuid())
  clinicId        String?
  userId          String
  period          String   // "2026-04" (year-month)
  appointments    Int
  totalRevenue    Float
  commissionRate  Float    // the rate applied
  commissionType  String   // percentage or fixed
  commissionAmount Float   // calculated commission
  adjustments     Float    @default(0) // manual adjustments (+/-)
  finalAmount     Float    // commissionAmount + adjustments
  status          String   @default("pending") // pending | approved | paid
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clinicId])
  @@index([userId])
  @@index([period])
}

// ─── Payroll ─────────────────────────────────────────────────────────────

model SalaryConfig {
  id              String   @id @default(cuid())
  clinicId        String?
  userId          String   @unique
  country         String   @default("SG") // "SG" | "IN" | "MY"
  baseSalary      Float    // monthly base salary
  salaryType      String   @default("monthly") // "monthly" | "hourly"
  hourlyRate      Float?   // if hourly
  age             Int?     // employee age (for age-based CPF in SG)
  allowances      String   @default("[]") // JSON: [{ name: "Transport", amount: 200 }, ...]
  deductions      String   @default("[]") // JSON: [{ name: "Insurance", amount: 50 }, ...]
  cpfEmployee     Float    @default(20) // employee CPF rate % (Singapore) — kept as override
  cpfEmployer     Float    @default(17) // employer CPF rate % — kept as override
  bankName        String?
  bankAccount     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clinicId])
}

model Payroll {
  id              String   @id @default(cuid())
  clinicId        String?
  userId          String
  period          String   // "2026-04"
  country         String   @default("SG") // "SG" | "IN" | "MY"

  // Earnings
  baseSalary      Float
  totalAllowances Float    @default(0)
  commission      Float    @default(0)
  overtime        Float    @default(0)
  overtimeHours   Float    @default(0)  // MOM: Overtime Hours Worked
  bonus           Float    @default(0)
  grossPay        Float

  // Deductions
  cpfEmployee     Float    @default(0)
  cpfEmployer     Float    @default(0)
  unpaidLeave     Float    @default(0) // deduction for unpaid leave days
  otherDeductions Float    @default(0)
  totalDeductions Float
  employerContributions Float @default(0) // total employer statutory cost
  taxWithholding  Float    @default(0) // monthly tax withholding (TDS/PCB)
  statutoryBreakdown String @default("[]") // JSON of all statutory items

  // Net
  netPay          Float

  // Meta
  workingDays     Int      @default(0)
  leaveDays       Int      @default(0)
  unpaidLeaveDays Int      @default(0)

  paymentMode     String   @default("bank_transfer") // MOM: "bank_transfer" | "cash" | "cheque"
  status          String   @default("draft") // "draft" | "confirmed" | "paid"
  paidAt          DateTime?
  notes           String?
  allowanceBreakdown String @default("[]") // JSON array
  deductionBreakdown String @default("[]") // JSON array

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clinicId])
  @@index([userId])
  @@index([period])
  @@unique([clinicId, userId, period])
}

// ─── Key Employment Terms (KET) — MOM Singapore ─────────────────────────

model KeyEmploymentTerms {
  id              String   @id @default(cuid())
  clinicId        String?
  userId          String
  issuedDate      DateTime @default(now())
  status          String   @default("draft") // "draft" | "issued" | "superseded"

  // Section A — Employment Details
  companyName     String
  placeOfWork     String?
  employeeName    String
  nricFin         String?
  jobTitle        String
  employmentType  String   @default("full_time") // "full_time" | "part_time"
  mainDuties      String?
  employmentStartDate DateTime?
  employmentEndDate   DateTime? // only for fixed-term contracts

  // Section B — Working Hours and Rest Day
  dailyWorkingHours   String?  // e.g. "8" or "5"
  workStartEndTime    String?  // e.g. "Mon-Fri: 9am-6pm, Sat: 9am-1pm"
  breakDuration       String?  // e.g. "1 hour"
  workingDaysPerWeek  String?  // e.g. "5.5" or "4"
  restDays            String?  // e.g. "Sunday" or "Sunday, Saturday"

  // Section C — Salary
  salaryPeriod        String?  // "1st to last day of the month"
  salaryFrequency     String   @default("monthly") // "hourly" | "daily" | "weekly" | "fortnightly" | "monthly"
  overtimePaymentPeriod String? // if different from salary period
  overtimeFrequency   String?  // "hourly" | "daily" | "weekly" | "fortnightly" | "monthly"
  salaryPaymentDate   String?  // e.g. "2nd of every calendar month"
  overtimePaymentDate String?  // e.g. "2nd of every calendar month"
  basicRate           String?  // e.g. "$2,000.00 per month" or "$6/hr"
  grossRate           String?  // e.g. "$2,100.00 per month"
  overtimeRate        String?  // e.g. "1.5x hourly basic rate ($15.80)"
  fixedAllowances     String   @default("[]") // JSON: [{ item: "Uniform", amount: 50 }]
  fixedDeductions     String   @default("[]") // JSON: [{ item: "CDAC", amount: 1 }]
  otherSalaryComponents String? // e.g. "Productivity incentive"
  cpfApplicable       Boolean  @default(true)

  // Section D — Leave and Medical Benefits
  annualLeaveDays     String?  // e.g. "14" (days or hours for part-time)
  sickLeaveDays       String?  // e.g. "14"
  hospitalisationLeaveDays String? // e.g. "60"
  otherLeave          String?  // e.g. "16 weeks Maternity Leave"
  medicalBenefits     String?  // e.g. "Full reimbursement for medical examination fee"

  // Section E — Others
  probationLength     String?  // e.g. "1 month" or "N.A."
  probationStartDate  DateTime?
  probationEndDate    DateTime?
  noticePeriod        String?  // e.g. "1 month notice or 1 month salary in lieu of notice"

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([clinicId])
  @@index([userId])
}

// ─── Audit Log ───────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  clinicId  String?
  userId    String?
  userName  String
  action    String   // create | update | delete
  entity    String   // patient | appointment | invoice etc
  entityId  String?
  details   String?  // JSON
  ipAddress String?
  createdAt DateTime @default(now())
}
