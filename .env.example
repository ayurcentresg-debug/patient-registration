DATABASE_URL="file:./dev.db"

# Auth — REQUIRED: Generate a random 64-char secret (e.g. openssl rand -base64 48)
JWT_SECRET="change-this-to-a-random-64-char-secret-before-deploying-to-prod"

# App
NEXT_PUBLIC_APP_NAME="AyurGate"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email — Resend (primary) or SMTP (fallback)
RESEND_API_KEY=""
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="AyurGate <noreply@ayurgate.com>"

# Marketing Email — Gmail SMTP (for bulk / marketing emails)
MARKETING_SMTP_HOST="smtp.gmail.com"
MARKETING_SMTP_PORT="587"
MARKETING_SMTP_USER="info@ayurgate.com"
MARKETING_SMTP_PASS="your-app-password"
MARKETING_EMAIL_FROM="AyurGate <info@ayurgate.com>"

# Twilio WhatsApp Configuration
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"

# Stripe (Payments)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PROFESSIONAL=""
STRIPE_PRICE_ENTERPRISE=""

# Super Admin
SUPER_ADMIN_EMAIL=""
SUPER_ADMIN_PASSWORD=""

# Admin notifications (receives new registration/subscription emails)
ADMIN_NOTIFICATION_EMAIL=""

# Cron / Backups — REQUIRED for /api/cron/backup to work
# Generate with: openssl rand -hex 32
CRON_SECRET=""
# Override default backup/report recipient
DAILY_REPORT_EMAIL="ayurcentresg@gmail.com"

# Offsite DB backup — optional. All four required vars must be set for offsite
# upload to activate; otherwise the backup stays local-only. See
# docs/runbooks/database-backup.md for full setup.
# For AWS S3: leave BACKUP_S3_ENDPOINT blank and use the real region.
# For Cloudflare R2: set endpoint and use region "auto".
BACKUP_S3_BUCKET=""
BACKUP_S3_ACCESS_KEY_ID=""
BACKUP_S3_SECRET_ACCESS_KEY=""
BACKUP_S3_REGION=""
BACKUP_S3_ENDPOINT=""
BACKUP_S3_PREFIX="backups/"
